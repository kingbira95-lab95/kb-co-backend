# ══════════════════════════════════════════════════════════════════════════════
#  KB & Co Backend — Environment Variables
#
#  LOCAL DEV:  Copy this file to .env and fill in the values.
#  RAILWAY:    Set these as environment variables in the Railway dashboard.
#              The DATABASE_URL and PORT are injected automatically when you
#              add a PostgreSQL plugin — you do NOT need to set them manually.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL:   Use postgresql+asyncpg://... (asyncpg driver required by SQLAlchemy async)
# RAILWAY: Railway sets DATABASE_URL automatically as  postgresql://...
#          Our config.py normalises it to +asyncpg automatically.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kbco

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# RAILWAY: set this to your Railway public URL, e.g.:
#   https://your-app.up.railway.app/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Flutterwave ───────────────────────────────────────────────────────────────
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_WEBHOOK_SECRET=your-webhook-secret
FLW_BASE_URL=https://api.flutterwave.com/v3

# ── Termii SMS ────────────────────────────────────────────────────────────────
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=KB-Co
TERMII_BASE_URL=https://api.ng.termii.com/api

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@kbco.invest
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM_NAME=KB & Co Investment
EMAIL_FROM=noreply@kbco.invest

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=KB & Co Corporate Investment Limited
# RAILWAY: set FRONTEND_URL to your Vercel/Netlify URL, e.g. https://kbco.vercel.app
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# RAILWAY: set ENVIRONMENT=production
ENVIRONMENT=development
NGX_SCRAPE_INTERVAL_MINUTES=1440

# ── Redis (optional) ─────────────────────────────────────────────────────────
# RAILWAY: add a Redis plugin and Railway sets REDIS_URL automatically
REDIS_URL=redis://localhost:6379/0

# ── Railway-injected variables (DO NOT SET MANUALLY) ─────────────────────────
# Railway sets these automatically when you add plugins:
#   PORT              — the port uvicorn should listen on
#   DATABASE_URL      — PostgreSQL connection string (postgres://...)
#   PGHOST            — PostgreSQL host
#   PGPORT            — PostgreSQL port
#   PGUSER            — PostgreSQL username
#   PGPASSWORD        — PostgreSQL password
#   PGDATABASE        — PostgreSQL database name
#   RAILWAY_ENVIRONMENT — set to "production" by Railway
